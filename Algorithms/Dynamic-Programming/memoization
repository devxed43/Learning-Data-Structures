def memoized_add_to_80():
    cache = {}

    def inner(n):
        if n in cache:
            return cache[n]
        else:
            print('this ran because value not in cache yet')
            cache[n] = n + 80
            return cache[n]

    return inner


# 1.) the moment I run this, memoize now points at inner
memoized = memoized_add_to_80()

# 2.) when I run this, 10 plugs into inner, and cache updates
print('1 set key:', memoized(10))
print('2 retrieve key:', memoized(10))

