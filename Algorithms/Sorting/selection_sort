numbers = [99, 44, 6, 2, 1, 5, 63, 87, 283, 4, 0]


def selection_sort(array):
    count = 0
    # outer i loop moves sorted boundary forward
    # -1 because last elem will already be in place
    for i in range(len(array) - 1):
        print(array)

        # assume current position holds minimum
        # on first pass, min is 99, min_index = 0

        minimum = array[i]  # array[0] = 99
        minimum_index = i  # index 0

        # inner loop scans everything to the right of i -> 44 onward...
        # looks for anything smaller than current minimum
        # i+1 to prevent comparing it with itself
        for j in range(i+1, len(array)):
            # tracks num of comparisons made
            count += 1

            # if value after j is smaller than 99, that becomes new minimum
            if array[j] < minimum:
                # make minimum the j value
                minimum = array[j]
                # the index of that j value is new minimum_index
                minimum_index = j

        # if minimum_index is not equal to i
        # this is outer loop of i checking, NOT the inner J loop
        # if does change, then we
        # 
        # if minimum_index is longer what we had in i at the top, then do the switch 
        if minimum_index != i:
            array[minimum_index], array[i] = array[i], array[minimum_index]
    return f'{array} \nNumber of operations = {count}'


selection_sort(numbers)
