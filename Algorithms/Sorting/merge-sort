(* so it merges the single elements at the bottom of the final iteration back up into the left side first and then the single elements at the bottom of the final iteration bac up into the right side second *)


count = 0

(* # merge_sort recursively splits both halves then returns them joined at end *)
def merge_sort(array):
    if len(array) == 1:
        return array
    else:
        mid = len(array)//2
        left_array = array[:mid]
        right_array = array[mid:]
        print(f'Left : {left_array}')
        print(f'Right : {right_array}')
        # splits until all are single
        # merges the items in merge_sort fn
        # putting them in sorted array
        return merge(merge_sort(left_array), merge_sort(right_array))

(* # compares two sorted arrays and combines them *)


def merge(left, right):
    l = len(left)
    r = len(right)

    left_index = 0
    right_index = 0
    sorted_array = []

    # loop both lists
    while (left_index < l and right_index < r):

        # track comparisons
        global count
        count += 1
        (* # if left elem is smaller than right, append smaller left item into sortedArray,
        # increase index to increment loop

        # if the number value at that index in the left list
        # if the number value at that index in the right list,
        # append to sorted array *)
        if left[left_index] < right[right_index]:
            sorted_array.append(left[left_index])
            left_index += 1
        (* # if number in right list is smaller than number in left list *)
        else:
            sorted_array.append(right[right_index])
            right_index += 1
    print(sorted_array + left[left_index:] + right[right_index:])

    (* # so in the left list, 
    # the value at left_index onward to the end of the left list, 
    # we catch and same for right list *)
    return sorted_array + left[left_index:] + right[right_index:]


array = [5, 9, 3, 10, 45, 2, 0]
print(merge_sort(array))

